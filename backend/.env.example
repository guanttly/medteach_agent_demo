# ===== 演示模式 =====
# mock = 全部本地数据；real = 仅真实接口；hybrid = 优先真实失败回退（推荐）
DEMO_MODE=hybrid

# ===== Agent 核心 =====
# 说明：真实大模型现在由文件底部「真实智能体大脑」区块控制（填 DEEPSEEK_API_KEY 即生效）。
# 下面的 AGENT_MODE 为旧开关，仅用于 /api/health 展示，不再决定是否调用大模型。
AGENT_MODE=simulated
CLAUDE_CORE_DIR=../medteach-agent-core
CLAUDE_TIMEOUT_SECONDS=30

# ===== 演示节奏（秒）=====
STEP_DELAY=0.9
PROGRESS_DELAY=1.4

# ===== 阿里云智能语音交互 TTS =====
# 方式 A：直接提供 NLS AccessToken（与 AppKey 搭配；不是 sk- 开头的大模型 API Key）
ALIYUN_NLS_TOKEN=
# 方式 B：提供 AccessKey，由服务端自动换取 NLS Token（长期运行推荐此方式）
ALIYUN_AK_ID=
ALIYUN_AK_SECRET=
# 两种方式都需要 AppKey
ALIYUN_NLS_APPKEY=
ALIYUN_NLS_REGION=cn-shanghai
# 推荐音色：zhixiaobai / zhixiaomei / aixia / xiaoyun 等
ALIYUN_NLS_VOICE=zhixiaobai
ALIYUN_NLS_FORMAT=mp3
ALIYUN_NLS_SAMPLE_RATE=16000

# ===== 教学平台（real / hybrid 模式时使用）=====
TEACHING_PLATFORM_BASE_URL=
TEACHING_PLATFORM_USERNAME=
TEACHING_PLATFORM_PASSWORD=
# 平台租户标识，请求头 platId（默认 0）
TEACHING_PLATFORM_PLAT_ID=0
# 自签证书环境置 false 跳过 SSL 校验
TEACHING_PLATFORM_VERIFY_SSL=false
# 写操作开关（create_exam_draft / publish_exam），演示默认 false 只读
# 注：关闭时写操作不会报错，而是返回「将要发送的请求体」做 Dry-run 预演，安全可验证。
TEACHING_PLATFORM_ALLOW_WRITE=false
# 是否信任系统代理环境变量（http_proxy 等）。默认 false = 直连平台、绕过代理，
# 规避代理层导致的 SSL UNEXPECTED_EOF / 超时抖动（实测可显著提速并降低偶发失败）。
TEACHING_PLATFORM_TRUST_ENV=false
# 单次请求遇到瞬时网络/TLS 抖动时的重试次数（默认 2）
TEACHING_PLATFORM_MAX_RETRIES=2
# 只读模块预热缓存有效期（秒）。演示前「一键预热」回填，现场命中即秒开真数据（默认 600）
TEACHING_PLATFORM_CACHE_TTL=600
# 指定演示用考试 ID（预览/进度/成绩优先取它）。留空 = 自动取最近一场已结束考试
TEACHING_PLATFORM_DEMO_EXAM_ID=

# ===== 真实智能体大脑：分层接入（对话层 flash 直连 ds ｜ 执行层 CC + ds v4-pro）=====
# 分层说明：
#   · 对话层（进入技能前的自然聊天 / 意图识别）：始终用 flash 模型「直连」DeepSeek，低延迟、可流式。
#   · 执行层（真正执行 Agent 任务 / arrange_exam 技能）：LLM_PROVIDER=claude_cli 时走 CC + DeepSeek v4-pro。
# 只要填入 DEEPSEEK_API_KEY，两层即生效；任何失败都会自动回退本地确定性编排（fallback）。
LLM_ENABLED=true
# deepseek = 执行层也直连 DeepSeek；claude_cli = 执行层走本机 Claude Code CLI + DeepSeek 后端
LLM_PROVIDER=deepseek
# 在这里填 DeepSeek API Key（sk- 开头）。留空 = 仅本地兜底演示。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 执行层（Agent 任务，CC + ds）模型：强模型
DEEPSEEK_AGENT_MODEL=deepseek-v4-pro
# 对话层（聊天 / 意图，flash 直连 ds）模型：快模型
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
# 对话层是否开启思考模式（默认 false：低延迟、可流式、temperature 生效）
DEEPSEEK_CHAT_THINKING=false
# 对话层流式回复最大 token（控制语音播报时长）
LLM_CHAT_MAX_TOKENS=300
# 兼容旧字段（=执行层模型），新代码请用 DEEPSEEK_AGENT_MODEL
DEEPSEEK_MODEL=deepseek-v4-pro
LLM_TIMEOUT_SECONDS=20
# 当 LLM_PROVIDER=claude_cli 时：请确认本机已安装 Claude Code CLI（终端能直接运行 claude），
# 上面的 DEEPSEEK_* 会自动注入给 CLI（等价于 ANTHROPIC_BASE_URL/AUTH_TOKEN/MODEL）。

# ===== 语音交互·智能体引擎 =====
# 语音业务问答用哪个引擎生成「最终口播话术」：
#   · hybrid（默认/推荐）：DeepSeek flash 快路径——意图秒级识别 + 按问法自然改写确定性事实，
#       300ms~3s 出话，展厅流畅无感；真实工具箱取数照常刷新大屏面板。
#   · claude：交给本机 Claude Code 自主调真实工具箱（MCP）+ 总结，完整落地
#       「意图识别 → 交给 Claude 工具调用总结 → 语音回答」；较慢（CLI 冷启动 + 多轮工具），
#       失败/超时自动回退 DeepSeek 快路径，再回退确定性事实，三层兜底永不翻车。
#   · deepseek：仅 DeepSeek 快路径，关闭 Claude 自主通道。
AGENT_ENGINE=hybrid
# 语音意图是否用 LLM 语义识别（正则先行，未命中再问 LLM；关掉则纯正则）
VOICE_INTENT_LLM=true
# 业务回答是否用 LLM 按问法自然改写（关掉则直接播报确定性事实话术）
VOICE_SUMMARY_LLM=true
# 语音关键路径的 LLM 预算（秒）：超时即回退，保证不卡顿
VOICE_INTENT_LLM_BUDGET=1.5
VOICE_SUMMARY_LLM_BUDGET=3.0
# Claude 自主调工具（AGENT_ENGINE=claude）单次硬超时（秒），超时回退快路径
CLAUDE_AGENTIC_TIMEOUT=45
