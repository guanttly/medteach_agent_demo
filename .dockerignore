# ===== 版本控制 / 构建产物 =====
.git
.gitignore
*.log

# ===== Python =====
**/__pycache__/
**/*.pyc
**/*.pyo
.venv/
venv/
backend/.venv/

# ===== Node / 前端（镜像内重新安装 + 构建）=====
node_modules/
frontend/node_modules/
frontend/dist/

# ===== 密钥 / 运行时凭据（切勿打进镜像）=====
**/.env
!**/.env.example
**/.mcp.json
backend/certs/
*.pem

# ===== 文档 / 杂项（运行时不需要，加速构建上下文）=====
docs/
*.md
!README.md

# ===== 系统 =====
.DS_Store
.vscode/
