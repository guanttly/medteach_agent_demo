# 云端 / Docker 部署环境变量模板
# 用法（二选一）：
#   · docker compose：复制为同目录 .env（compose 自动读取做变量替换）  cp .env.docker.example .env
#   · docker run    ：复制后用 --env-file 注入                         docker run --env-file .env.docker.example ...
# 全部留空也能跑（纯本地兜底演示）；按需填入下列凭据即可点亮真实能力。

# ===== 演示模式 / 智能体引擎 =====
DEMO_MODE=hybrid
AGENT_ENGINE=hybrid
LLM_ENABLED=true

# ===== DeepSeek（cc + ds）：填了即点亮真实大模型大脑 =====
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_AGENT_MODEL=deepseek-v4-pro
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash

# ===== Claude 自主调工具（agentic）/ 语音授权 =====
# 单次自主调工具硬超时（秒）
CLAUDE_AGENTIC_TIMEOUT=45
# 权限模式：留空=用 CLI 默认（headless 已足够）；可选 default / acceptEdits / bypassPermissions
CLAUDE_PERMISSION_MODE=
# 语音授权链路：true=本场首次让 Claude 访问真实平台数据前先口头征求授权（演示授权交互时开）
CLAUDE_VOICE_AUTH=false

# ===== 阿里云智能语音交互 TTS（留空=仅文字，不发声）=====
# 方式 A：直接给 NLS AccessToken
ALIYUN_NLS_TOKEN=
# 方式 B：给 AccessKey，由服务端自动换取（长期运行推荐）
ALIYUN_AK_ID=
ALIYUN_AK_SECRET=
# 两种方式都需要 AppKey
ALIYUN_NLS_APPKEY=
ALIYUN_NLS_REGION=cn-shanghai
ALIYUN_NLS_VOICE=zhixiaobai

# ===== 教学平台（real / hybrid 模式接真实数据）=====
TEACHING_PLATFORM_BASE_URL=
TEACHING_PLATFORM_USERNAME=
TEACHING_PLATFORM_PASSWORD=
TEACHING_PLATFORM_PLAT_ID=0
TEACHING_PLATFORM_VERIFY_SSL=false
TEACHING_PLATFORM_ALLOW_WRITE=false

# ===== 传输 =====
# 1 = 启用 HTTPS（容器内生成自签证书；远程经 IP 访问麦克风/语音识别必需安全上下文）
HTTPS=0
# 对外端口（compose 用）
PORT=8000
